; a = 000AH
MVI H, 00H
MVI L, 0AH
SHLD 1000H        ; store a (2 bytes)
; b = 0014H
MVI H, 00H
MVI L, 14H
SHLD 1002H        ; store b (2 bytes)
; Load a into HL
LHLD 1000H        ; HL = dividend
; Load b into DE
LDA 1002H
MOV E, A          ; low byte
LDA 1003H
MOV D, A          ; high byte

; Initialize quotient = 0000
MVI B, 00H
MVI C, 00H        ; BC = quotient

LOOP:
    ; Compare HL and DE
    MOV A, L
    SUB E
    MOV A, H
    SBB D
    JC END        ; if HL < DE → stop

    ; HL = HL - DE
    MOV A, L
    SUB E
    MOV L, A

    MOV A, H
    SBB D
    MOV H, A

    ; Increment quotient (BC)
    INX B

    JMP LOOP

END:
    ; Store quotient
    MOV H, B
    MOV L, C
    SHLD 1004H    ; store c (2 bytes)

HLT
ASW 17
